# Dummy, non-secret values so `import.meta.env.VITE_FIREBASE_API_KEY` is always present
# under `npm run test` (Vitest mode "test"), regardless of whether a developer has a
# local .env with real credentials. Without this, src/lib/services/firebase.ts's
# isDevMode check diverges between local runs (real .env present) and CI (no .env),
# since firebase/app and firebase/auth are already fully mocked in src/test/setup.ts
# and never make real network calls either way.
VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=test-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=test-project
VITE_FIREBASE_STORAGE_BUCKET=test-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
