{
  "name": "retro-rocket",
  "version": "1.5.0",
  "description": "A modern, collaborative tool for Scrum teams to manage their retrospectives.",
  "main": "src/main.tsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "start": "npm run dev",
    "lint": "eslint src --ext ts,tsx",
    "deploy": "npm run build && vercel --prod",
    "test": "vitest --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:coverage:watch": "vitest --coverage --watch --config vitest.config.ts",
    "test:coverage:ui": "vitest --coverage --ui --config vitest.config.ts",
    "test:threshold": "vitest run --coverage --reporter=verbose --config vitest.config.ts",
    "emulators": "firebase emulators:start --only auth,firestore",
    "e2e": "firebase emulators:exec --only auth,firestore \"playwright test\"",
    "test:accuracy": "RUN_ACCURACY_BENCH=1 vitest run src/test/features/boards/sentiment/accuracy.bench.test.ts --config vitest.config.ts",
    "bench:sentiment": "RUN_MODEL_EVAL=1 vitest run src/test/features/boards/sentiment/evaluation/benchmark.test.ts --config vitest.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.20",
    "@headlessui/react": "^2.2.7",
    "@huggingface/transformers": "^3.8.1",
    "@react-pdf/renderer": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "clsx": "^1.2.1",
    "date-fns": "^4.1.0",
    "docx": "^9.5.0",
    "file-saver": "^2.0.5",
    "firebase": "^10.0.0",
    "framer-motion": "^10.18.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-i18next": "^15.6.1",
    "react-router-dom": "^6.8.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@actions/cache": "^6.2.0",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/html2canvas": "^0.5.35",
    "@types/react-datepicker": "^6.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.24.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.0",
    "puppeteer": "^24.17.1",
    "semantic-release": "^25.0.8",
    "tailwindcss": "^3.3.0",
    "typescript-eslint": "^8.65.0",
    "vite": "^4.0.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "scrum",
    "retrospective",
    "collaboration",
    "react",
    "firebase"
  ],
  "author": "Your Name",
  "license": "GPL-3.0-only"
}
